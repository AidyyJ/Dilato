# Environment Configuration
# Copy this to .env and fill in your actual values

# ---------------------------------------------------------------------------
# PostgreSQL (required for docker-compose.prod.yml)
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reseller

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/reseller
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/reseller

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REQUIRED for production: set a strong password (leave empty only for local dev without auth)
REDIS_PASSWORD=
# Optionally override the full URL directly (auto-built from components if empty)
REDIS_URL=

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
# Optionally override broker/result URLs directly (auto-built from components if empty)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# REQUIRED: generate a strong random secret (e.g. openssl rand -hex 32)
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# ---------------------------------------------------------------------------
# CORS (for local development)
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute

# ---------------------------------------------------------------------------
# Amazon Product Advertising API
# ---------------------------------------------------------------------------
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_HOST=webservices.amazon.com
AMAZON_REGION=us-east-1

# ---------------------------------------------------------------------------
# eBay REST API
# ---------------------------------------------------------------------------
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_DEV_ID=
EBAY_RU_NAME=
EBAY_SITE_ID=0
EBAY_API_BASE_URL=https://api.ebay.com

# ---------------------------------------------------------------------------
# Sourcing defaults
# ---------------------------------------------------------------------------
DEFAULT_PROFIT_MARGIN_THRESHOLD=0.15
DEFAULT_MAX_PRICE_USD=200.0
DEFAULT_MIN_PRICE_USD=5.0

# ---------------------------------------------------------------------------
# Sync intervals (seconds)
# ---------------------------------------------------------------------------
STOCK_SYNC_INTERVAL=21600
PRICE_SYNC_INTERVAL=7200

# ---------------------------------------------------------------------------
# Sync defaults
# ---------------------------------------------------------------------------
DEFAULT_AVAILABLE_QUANTITY=5
PRICE_SYNC_MIN_DELTA_PERCENT=1.0
